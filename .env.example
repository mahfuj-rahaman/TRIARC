# Tier 1 -- local OpenAI-compatible endpoint. On the AMD GPU pod for the hackathon
# deployment; for local dev, Ollama's OpenAI-compat API (http://localhost:11434/v1)
# works too -- LOCAL_MODEL must match a model you've pulled (`ollama list`).
LOCAL_ENDPOINT=http://localhost:8000/v1
LOCAL_MODEL=tier1-router

# Tiers 2-3 -- Fireworks AI (never referenced from configs/models.yaml directly)
FIREWORKS_API_KEY=
FIREWORKS_GEMMA_MODEL=accounts/fireworks/models/gemma-...
FIREWORKS_LARGE_MODEL=accounts/fireworks/models/...

# Optional -- all default sensibly; uncomment to override.
# MODELS_CONFIG=configs/models.yaml     # path to the model registry
# TRIARC_WORKSPACE=.                    # sandboxed project directory a run operates on
# TRIARC_API_URL=http://127.0.0.1:8080  # where ui/tui and ui/web point (client-side)
# TRIARC_WEB_ALLOWLIST=                 # comma-separated allowed domains for the web MCP server
# TRIARC_REDACTION_LOG=.triarc/redaction.log
